---
import Section from "@/components/Section.astro";

---

<Section>
    <div class="container">
        <nav>
            <a href="#inicio">Inicio</a>
            <a href="#proyectos">Proyectos</a>
            <a href="#sobremi">Sobre mi</a>
        </nav>
    </div>
</Section>

<style>
    .container {
        display: flex;
        justify-content: flex-end;
        margin: 25px 30px;
    }

    nav {
        display: flex;
        gap: 25px;
        padding: 12px 16px;
        border-radius: 100px;
        border-style: solid;
        border-width: 1px;
        border-color: #868686;
        background-color: #191c21;
    }

    a {
        font-family: "Arimo", sans-serif;
        text-decoration: none;
        font-size: 16px;
        color: #E5E5E5;
    }

    a:hover {
        color: #979797;
    }
</style>
