---
import Section from "@/components/Section.astro";
import circle from "@/icons/circle.svg?url";
---

<Section>
  <div class="container">
    <div class="nav">
      <a href="#proyectos">Proyectos</a>
      <a href="#sobremi">Sobre mi</a>
    </div>

    <div class="dark_mode">
      <a
        id="toggleTheme"
        onclick="const root = document.documentElement;
        const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);"
        ><img src={circle} alt="toggleTheme" /></a
      >
    </div>
  </div>
</Section>

<style>
  .container {
    display: flex;
    justify-content: flex-end;
    margin: 25px;
    gap: 10px;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 25px;
    padding: 12px 18px;
    border-radius: 100px;
    border-style: solid;
    border-width: 1px;
    border-color: var(--border-color);
    background-color: var(--bg-a-color);
  }

  a {
    font-family: "Arimo", sans-serif;
    text-decoration: none;
    font-size: 16px;
    color: var(--txt-color);
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  a:hover {
    opacity: 50%;
  }

  img {
    width: 35px;
    height: 35px;
    opacity: 70%;
  }

  img:hover {
    opacity: 50%;
  }

  .dark_mode {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    width: 70px;
    height: 50px;
    border-radius: 100px;
    border: 1px solid var(--border-color);
    background-color: var(--bg-a-color);
  }
</style>
