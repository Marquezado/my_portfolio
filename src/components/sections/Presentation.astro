---
import { basics } from "@cv";
import Section from "@/components/Section.astro";

const { profiles } = basics;
---

<Section>
  <div class="container">
    <div class="eslogan">
      <div class="container_eslogan">
        <h1>Hola soy David, desarrollador de software</h1>
        <div class="lenguajes_collagues">
          <img
            class="big"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
          />
          <img
            class="medium"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
          />
          <img
            class="small-node"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original-wordmark.svg"
          />
          <img
            class="small-springboot"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
          />
        </div>
      </div>
    </div>
    <div class="section_profiles_description">
      <div class="profiles">
        {
          profiles.map(({ network, url }) => {
            return (
              <a
                href={url}
                title={`Visitar ${network}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {network}
              </a>
            );
          })
        }
      </div>
      <div class="description">
        <p>
          Conocimientos fundamentales y gran interés en el desarrollo de
          aplicaciones y soluciones tecnológicas, junto a un equipo.
        </p>
      </div>
    </div>
  </div>
</Section>

<style>

  h1 {
    font-family: "Noto Serif JP", sans-serif;
    font-weight: 500;

    font-size: clamp(2rem, 5vw, 4.5rem);  
    width: 100%;
    color: var(--txt-color);
  }

  .eslogan {
    display: flex;
    margin-top: 60px;
  }

  .container_eslogan {
    display: flex;
    align-items: center;

    gap: 1rem;
    width: 100%;
  }

  .lenguajes_collagues {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 90px;
    gap: 15px;
    padding: 20px;
  }

  .lenguajes_collagues img {
    width: 100%;
    height: 100%;
    border-radius: 15px;
  }

  .big {
    grid-column: span 3;
    grid-row: span 3;
  }

  .medium {
    grid-column: span 2;
    grid-row: span 2;
  }

  .small-node,
  .small-springboot {
    grid-column: span 1;
    grid-row: span 1;
  }

  .section_profiles_description {
    display: flex;
    gap: 2rem;
    align-items: flex-end;
    margin-top: 2rem;
  }

  .profiles {
    display: flex;
    gap: 2rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .profiles a {
    font-family: "Arimo", sans-serif;
    color: #777;

    display: inline-flex;
    align-items: center;
    justify-content: center;

    background-color: var(--bg-a-color);
    border: 1px solid var(--border-color);

    padding: 4px;
    height: 30px;
    width: 80px;

    border-radius: 20px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .profiles a:hover {
    color: var(--txt-color);
    background: var(--bg-a-color);
  }

  .description {
    display: flex;
    flex-direction: column;
    text-align: right;

    width: 60%;
  }

  p {
    margin: 0;
    font-size: clamp(1rem, 2vw, 1.5rem);
    font-family: "Arimo", sans-serif;
    color: var(--txt-color);
  }

  @media (max-width: 768px) {
    .container_eslogan {
      flex-direction: column;
    }
    .section_profiles_description {
      flex-direction: column;
      align-items: flex-start;
    }

    .description {
      width: 100%;
      text-align: left;
    }

    .profiles {
      width: 100%;
      justify-content: center;
    }

    .lenguajes_collagues {
      grid-template-columns: repeat(auto-fit, minmax(30px, 1fr));
      padding: 10px;
    }
  }

  @media (max-width: 480px) {
    .profiles {
      gap: 1rem;
    }

    .profiles a {
      width: 70px;
      font-size: 0.8rem;
    }

    .lenguajes_collagues {
      gap: 10px;
    }
  }
</style>
