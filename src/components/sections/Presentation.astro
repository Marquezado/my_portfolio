---
import { basics } from "@cv";
import Section from "@/components/Section.astro";

const { name, profiles } = basics;
---

<Section>
  <div class="container">
    <div class="eslogan">
      <div class="container_eslogan">
        <h1>Hola soy David, desarrollador de software</h1>
        <div class="lenguajes_collagues">
          <img
            class="big"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/java/java-original.svg"
          />
          <img
            class="medium"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg"
          />
          <img
            class="small-node"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/nodejs/nodejs-original-wordmark.svg"
          />
          <img
            class="small-springboot"
            src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/spring/spring-original.svg"
          />
        </div>
      </div>
    </div>
    <div class="section_profiles_description">
      <div class="profiles">
        {
          profiles.map(({ network, url }) => {
            return (
              <a
                href={url}
                title={`Visitar ${network}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {network}
              </a>
            );
          })
        }
      </div>
      <div class="description">
        <p>
          Conocimientos fundamentales y gran
          interés en el desarrollo de aplicaciones y soluciones tecnológicas,
          junto a un equipo.
        </p>
      </div>
    </div>
  </div>
</Section>

<style>
  .container {
    height: 750px;
  }

  .container_eslogan {
    display: flex;
    align-items: center;
  }

  .section_user {
    display: flex;
  }

  h1 {
    display: flex;
    font-family: "Noto Serif JP", sans-serif;
    font-weight: 500;
    font-size: 70px;
    width: 70%;
    color: var(--txt-color);
  }

  .profiles {
    display: flex;
    gap: 2rem;
    flex: 1;
    width: 40%;
  }

  .profiles a {
    font-family: "Arimo", sans-serif;
    color: #777;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-a-color);
    padding: 4px;
    height: 30px;
    width: 80px;
    border-radius: 20px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .profiles a:hover {
    background: var(--bg-a-color);
    color: var(--txt-color);
  }

  .section_profiles_description {
    display: flex;
    align-items: end;
    width: 100%;
    height: 230px;
  }

  .description {
    display: flex;
    text-align: right;
    flex-direction: column;
    width: 60%;
  }
  p {
    margin: 0;
    font-size: 1.5rem;
    font-family: "Arimo", sans-serif;
    color: var(--txt-color);
  }

  .eslogan {
    display: flex;
    margin-top: 60px;
  }

  .lenguajes_collagues {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-auto-rows: 120px;
    gap: 15px;
    padding: 20px;
  }

  .lenguajes_collagues img {
    width: 100%;
    height: 100%;
    border-radius: 15px;
  }

  .big {
    grid-column: span 3;
    grid-row: span 3;
  }

  .medium {
    grid-column: span 2;
    grid-row: span 2;
  }

  .small-node {
    grid-column: span 1;
    grid-row: span 1;
  }

  .small-springboot {
    grid-column: span 1;
    grid-row: span 1;
  }
</style>
