---
import Section from "../Section.astro";
import { projects } from "@cv";
---

<Section id="proyectos" title="Proyectos">
  <div class="container">
    <ul class="card-grid">
      {
        projects.map(({ name, url, description, tecnologies }) => (
          <li>
            <a
              href={url || "#"}
              title={`Ver el proyecto ${name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="card-link"
            >
              <article class="card">
                <header>
                  <h3>{name}</h3>
                  <p>{description}</p>
                </header>
                <footer>
                  <ul class="tecnologies-list">
                    {tecnologies.map(({ name, color }) => (
                      <li style={`--bg-color: ${color}`}>
                        <span>{name}</span>
                      </li>
                    ))}
                  </ul>
                </footer>
              </article>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Section>

<style>
  .card-link {
    height: 100%;
    text-decoration: none;
    color: inherit;
    display: block;
    border-radius: 12px;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    cursor: default;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 5rem;
  }

  .card {
    height: 100%;
    padding: 1.5rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    border-radius: 12px;
    background: var(--bg-target-color);
    border: 1px solid var(--border-color);

    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .card:hover{
    transform: translateY(-4px);
    box-shadow: 0 4px 12px var(--shadow-color);
  }

  .card h3 {
    color: var(--txt-color);
    font-family: "Arimo", sans-serif;
    margin: 0 0 0.5rem 0;
  }

  .card p {
    font-family: "Arimo", sans-serif;
    color: var(--txt-color);
    font-size: 0.95rem;
    margin: 0;
    opacity: 0.9;
  }

  .tecnologies-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0;
    padding: 0;
  }

  .tecnologies-list li {
    list-style: none;
    background: color-mix(in srgb, var(--bg-target-color), white 5%);
    font-family: "Arimo", sans-serif;
    font-size: 0.8rem;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    padding: 0.3rem 0.6rem;
    color: var(--txt-color);
    transition: transform 0.2 ease;
  }
  
  span {
    cursor: default;
  }

  .tecnologies-list li:hover {
    transform: scale(1.05);
  }

  @media (max-width: 600px) {
    .card-grid {
      grid-template-columns: 1fr;
    }

    .card {
      padding: 1.2rem;
    }
  }

  a {
    text-decoration: none;
    background: var(--bg-target-color);
    border-radius: 10px;
    border: 1px solid var(--border-color);
  }
</style>
